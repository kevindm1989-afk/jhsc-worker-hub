# =============================================================================
# JHSC Worker Hub — environment template
# =============================================================================
#
# Copy this file to `.env` for local development:
#     cp .env.example .env
#
# .env is gitignored. .env.example IS committed. NEVER replace the placeholder
# values below with real secrets in this file.
#
# Production secrets live in Fly Secrets (see SECURITY.md §3). Local dev
# secrets stay on your machine in `.env`.
#
# =============================================================================


# -----------------------------------------------------------------------------
# Workplace identity (non-negotiable #1)
# -----------------------------------------------------------------------------
# Workplace name, jurisdiction, and zone display names are loaded at runtime
# from these vars. No identifying strings live in source. See
# config/workplace.ts.

# Free-text display name for the workplace (e.g. "Plant 4"). Empty in dev.
WORKPLACE_DISPLAY_NAME=

# Jurisdiction: "ON" for Ontario OHSA, "CA-FED" for Canada Labour Code Part II.
WORKPLACE_JURISDICTION=ON

# Zone display names. Zone IDs (zone_1..zone_10) are STABLE and never change
# (non-negotiable #14). Only the display name is workplace-configurable.
# Leave blank to fall back to "Zone N".
ZONE_1_NAME=
ZONE_2_NAME=
ZONE_3_NAME=
ZONE_4_NAME=
ZONE_5_NAME=
ZONE_6_NAME=
ZONE_7_NAME=
ZONE_8_NAME=
ZONE_9_NAME=
ZONE_10_NAME=


# -----------------------------------------------------------------------------
# Database — local Postgres via docker-compose
# -----------------------------------------------------------------------------
# DO NOT COMMIT real production credentials. Production uses Neon in
# ca-central-1; that connection string lives in Fly Secrets only.
DATABASE_URL=postgresql://jhsc_dev:jhsc_dev_local_only@localhost:5432/jhsc_worker_hub_dev


# -----------------------------------------------------------------------------
# Application master key (field-level encryption per SECURITY.md §3)
# -----------------------------------------------------------------------------
# DO NOT COMMIT REAL KEYS. Generated via libsodium. In production this
# lives in Fly Secrets and is never logged or returned by any API. For
# local dev a throwaway value is fine — but still keep it in `.env`,
# never `.env.example`. 32 raw bytes, base64-encoded:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MASTER_KEY=


# -----------------------------------------------------------------------------
# Auth — Milestone 1.2 (ADR-0001, SECURITY.md §3)
# -----------------------------------------------------------------------------
# Ed25519 keypair for signing access JWTs. Generate with:
#   node -e "const c = require('crypto'); const { privateKey, publicKey } = c.generateKeyPairSync('ed25519'); console.log('priv:', privateKey.export({format:'der',type:'pkcs8'}).toString('base64')); console.log('pub:', publicKey.export({format:'der',type:'spki'}).toString('base64'));"
# In production both live in Fly Secrets. The private key is never logged.
AUTH_JWT_ED25519_PRIVATE_KEY_B64=
AUTH_JWT_ED25519_PUBLIC_KEY_B64=

# Key id for JWT header. Bump on rotation; the verifier accepts both the
# active and the previous kid for a grace window.
AUTH_JWT_ACTIVE_KID=k1

# WebAuthn relying-party configuration. RP_ID must be the registrable
# hostname (no scheme, no path); RP_ORIGIN is the full origin the browser
# will see. Dev defaults below talk to the Vite dev server.
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_ORIGIN=http://localhost:5173
WEBAUTHN_RP_NAME=JHSC Worker Hub

# Lockout ladder windows (SECURITY.md §3 — tuneable for tests, never in prod).
# Defaults match SECURITY.md exactly; override in .env only for development.
AUTH_LOCKOUT_SHORT_FAILS=5
AUTH_LOCKOUT_SHORT_WINDOW_SECONDS=900
AUTH_LOCKOUT_LONG_FAILS=10
AUTH_LOCKOUT_LONG_WINDOW_SECONDS=3600
AUTH_LOCKOUT_HARD_FAILS=20
AUTH_LOCKOUT_HARD_WINDOW_SECONDS=86400


# -----------------------------------------------------------------------------
# AI proxy (deferred to Release 3, Milestone 3.2)
# -----------------------------------------------------------------------------
# DO NOT COMMIT REAL KEYS. The Anthropic API key only ever lives on the
# ai-proxy Fly Machine, never in the main api process. See
# ARCHITECTURE.md §1.
AI_PROXY_URL=http://localhost:3002
AI_PROXY_SHARED_SECRET=
ANTHROPIC_API_KEY=


# -----------------------------------------------------------------------------
# Web Push / VAPID (deferred to Milestone 1.10 / Release 2)
# -----------------------------------------------------------------------------
# DO NOT COMMIT REAL KEYS. Generate via `web-push generate-vapid-keys` and
# store in Fly Secrets. The public key is fine to expose to the browser; the
# private key is server-only.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:replace-me@example.invalid


# -----------------------------------------------------------------------------
# Tigris object storage (S3-compatible, evidence files)
# -----------------------------------------------------------------------------
# DO NOT COMMIT REAL KEYS. Provisioned via `flyctl storage create` and stored
# in Fly Secrets. Files are encrypted client-side BEFORE upload — Tigris
# sees ciphertext only (ARCHITECTURE.md §1, SECURITY.md §3).
TIGRIS_BUCKET=
TIGRIS_ACCESS_KEY_ID=
TIGRIS_SECRET_ACCESS_KEY=
TIGRIS_ENDPOINT_URL=
TIGRIS_REGION=auto


# -----------------------------------------------------------------------------
# Service ports (dev)
# -----------------------------------------------------------------------------
WEB_PORT=5173
API_PORT=3001
AI_PROXY_PORT=3002


# -----------------------------------------------------------------------------
# Runtime flags
# -----------------------------------------------------------------------------
# NODE_ENV is set by tooling. Override only if you know why.
# NODE_ENV=development
