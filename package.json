{
  "name": "jhsc-worker-hub",
  "version": "0.0.0",
  "private": true,
  "description": "Single-workplace, worker-side JHSC tool. Ontario OHSA + federal CLC Part II.",
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "prepare": "husky",
    "dev": "pnpm --filter @jhsc/web dev",
    "dev:api": "pnpm --filter @jhsc/api dev",
    "dev:ai-proxy": "pnpm --filter @jhsc/ai-proxy dev",
    "build": "pnpm -r build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -p tsconfig.json --noEmit && pnpm -r typecheck",
    "test": "vitest run && pnpm -r test",
    "test:root": "vitest run",
    "test:e2e": "pnpm --filter @jhsc/web test:e2e",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "audit": "pnpm audit --audit-level=high"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "overrides": {
      "@esbuild-kit/core-utils>esbuild": ">=0.25.0"
    }
  }
}
