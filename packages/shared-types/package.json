{
  "name": "@jhsc/shared-types",
  "version": "0.0.0",
  "private": true,
  "description": "JHSC Worker Hub — shared type definitions (Result, AuditEventKind, AuthEventKind, branded IDs).",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./hazard-transitions": {
      "types": "./src/hazard-transitions.ts",
      "default": "./src/hazard-transitions.ts"
    },
    "./action-item-transitions": {
      "types": "./src/action-item-transitions.ts",
      "default": "./src/action-item-transitions.ts"
    },
    "./action-item-flag": {
      "types": "./src/action-item-flag.ts",
      "default": "./src/action-item-flag.ts"
    },
    "./meeting": {
      "types": "./src/meeting.ts",
      "default": "./src/meeting.ts"
    },
    "./action-item-closure": {
      "types": "./src/action-item-closure.ts",
      "default": "./src/action-item-closure.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vitest": "^4.1.0"
  }
}
