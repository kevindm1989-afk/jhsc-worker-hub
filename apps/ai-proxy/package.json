{
  "name": "@jhsc/ai-proxy",
  "version": "0.0.0",
  "private": true,
  "description": "JHSC Worker Hub — Anthropic API proxy (isolates the API key from the main api process). Scaffold only in 1.1; integration lands in Release 3 Milestone 3.2.",
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
