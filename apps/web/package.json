    "@jhsc/ui": "workspace:*",
    "@radix-ui/react-slot": "^1.1.1",
    "@simplewebauthn/browser": "^11.0.0",
    "class-variance-authority": "^0.7.1",
    "dexie": "^4.0.10",
    "framer-motion": "^11.15.0",
    "libsodium-wrappers": "0.7.15",
    "lucide-react": "^1.16.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.16.0",
