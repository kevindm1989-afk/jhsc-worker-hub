{
  "name": "@jhsc/api",
  "version": "0.0.0",
  "private": true,
  "description": "JHSC Worker Hub — Hono + Bun API service.",
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@jhsc/audit": "workspace:*",
    "@jhsc/crypto": "workspace:*",
    "@jhsc/shared-types": "workspace:*",
    "@lucia-auth/adapter-drizzle": "^1.1.0",
    "@oslojs/crypto": "^1.0.1",
    "@oslojs/encoding": "^1.1.0",
    "@oslojs/otp": "^1.0.0",
    "@simplewebauthn/server": "^11.0.0",
    "@simplewebauthn/types": "^11.0.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.14",
    "jose": "^5.9.6",
    "libsodium-wrappers-sumo": "0.7.15",
    "lucia": "^3.2.0",
    "postgres": "^3.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "@types/libsodium-wrappers-sumo": "^0.7.8",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
